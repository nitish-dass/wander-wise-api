### Create Baggage Data
POST {{baseUrl}}/{{tripId}}/baggages       
//baggage location handlers ko index ma define gareko
Content-Type: application/json
Authorization: Bearer {{token}}

{
    "name": "Suit"
}

### Get all bagggages
GET {{baseUrl}}/{{tripId}}/baggages
Authorization: Bearer {{token}}


### Get a specific baggages
GET {{baseUrl}}/{{tripId}}/baggages/6a0017f8db270fbb2fb28397
Authorization: Bearer {{token}}


###update a specific baggage
PATCH {{baseUrl}}/{{tripId}}/baggages/6a0017f8db270fbb2fb28397
Content-Type: application/json
Authorization: Bearer {{token}}


{
    "name": "Jeans",
    "completed": true
}

###Delete a specific baggages
DELETE {{baseUrl}}/{{tripId}}/baggages/6a0017f8db270fbb2fb28397
Authorization: Bearer {{token}}


### Create Itinerary
POST {{baseUrl}}/{{tripId}}/itineraries
Content-Type: application/json
Authorization: Bearer {{token}}

{
    "trip": "{{tripId}}",
    "title": "Day 1 in Pokhara",
    "description": "Arrival, lake walk, and dinner near Lakeside.",
    //"date": "2025-12-15",
    "startDate": "2025-12-15",
    "endDate": "2025-12-20",
    "activities": [
        {
            "name": "Check in at hotel",
            "time": "14:00",
            "notes": [
                "Confirm lake-view room",
                "Ask about breakfast timing"
            ]
        },
        {
            "name": "Walk around Phewa Lake",
            "time": "17:00",
            "notes": [
                "Bring a light jacket"
            ]
        }
    ]
}

### Get all itineraries
GET {{baseUrl}}/{{tripId}}/itineraries
Authorization: Bearer {{token}}

### Get a specific itinerary
GET {{baseUrl}}/{{tripId}}/itineraries/{{itineraryId}}
Authorization: Bearer {{token}}

### Update a specific itinerary
PATCH {{baseUrl}}/{{tripId}}/itineraries/{{itineraryId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
    "title": "Day 1 in Pokhara - Lakeside",
    "description": "Arrival, sunset walk, and dinner near Lakeside.",
    "date": "2025-12-15",
    "activities": [
        {
            "name": "Check in at hotel",
            "time": "14:00",
            "notes": [
                "Confirm lake-view room"
            ]
        },
        {
            "name": "Dinner at Lakeside",
            "time": "19:30",
            "notes": [
                "Reserve a table"
            ]
        }
    ]
}

### Delete a specific itinerary
DELETE {{baseUrl}}/{{tripId}}/itineraries/{{itineraryId}}
Authorization: Bearer {{token}}


