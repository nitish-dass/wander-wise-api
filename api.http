### create a new trip
POST {{baseUrl}}/trips
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "title": "Trip to the moon",
  "startDate": "2025-12-15",
  "endDate": "2025-12-16",
  "budget": {
    "total": 1000
  },
  "destinations": ["Moon", "Mars", "Jupiter"]
}

### Get all trips
GET {{baseUrl}}/trips
Authorization: Bearer {{token}}

### Get a trip by id
GET {{baseUrl}}/trips/{{tripId}}
Authorization: Bearer {{token}}

### Update trip
PATCH {{baseUrl}}/trips/{{tripId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "budget": {
    "expenses": [
        {
            "name": "taxi",
            "amount": 600
        }
    ]
  }
}

### Delete a trip
DELETE {{baseUrl}}/trips/{{tripId}}
Authorization: Bearer {{token}}

### send trip invitation
POST {{baseUrl}}/trips/{{tripId}}/invite
Content-Type: application/json
Authorization: Bearer {{token}}

{
    "collaboratorEmails": [
        "dass2005nd@gmail.com"
    ]
}

### Accept invite
GET {{baseUrl}}/trips/{{tripId}}/invite/accept?token={{invitationToken}}
Authorization: Bearer {{token}}